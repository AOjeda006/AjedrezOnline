@page
@model MenuPrincipalModel
@{
    ViewData["Title"] = "Menú Principal - ServidorAjedrez";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4>Menú Principal</h4>
                </div>
                <div class="card-body">
                    <div class="form-group mb-3">
                        <label for="playerNameEdit">Tu nombre:</label>
                        <input type="text" class="form-control" id="playerNameEdit" asp-for="NombreJugador">
                    </div>
                    
                    <hr />
                    
                    <h5>Crear Sala</h5>
                    <div class="form-group mb-3">
                        <label for="roomNameCreate">Nombre de la sala:</label>
                        <input type="text" class="form-control" id="roomNameCreate" placeholder="Ingresa el nombre de la sala">
                    </div>
                    <button class="btn btn-success mb-3" id="createRoomBtn">Crear Sala</button>
                    
                    <hr />
                    
                    <h5>Unirse a Sala</h5>
                    <div class="form-group mb-3">
                        <label for="roomNameJoin">Nombre de la sala:</label>
                        <input type="text" class="form-control" id="roomNameJoin" placeholder="Ingresa el nombre de la sala">
                    </div>
                    <button class="btn btn-info" id="joinRoomBtn">Unirse a Sala</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/menuPrincipal.js"></script>
}
