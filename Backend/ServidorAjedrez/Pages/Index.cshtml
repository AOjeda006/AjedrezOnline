@page
@model IndexModel
@{
    ViewData["Title"] = "Identificación - ServidorAjedrez";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4>Bienvenido a ServidorAjedrez</h4>
                </div>
                <div class="card-body">
                    <div class="form-group mb-3">
                        <label for="playerName">Nombre del Jugador:</label>
                        <input type="text" class="form-control" id="playerName" placeholder="Ingresa tu nombre">
                    </div>
                    <button class="btn btn-success w-100" id="continueBtn">Continuar</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/signalr/dist/browser/signalr.js"></script>
    <script src="~/js/identificacion.js"></script>
}
