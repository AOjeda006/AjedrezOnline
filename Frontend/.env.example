# Configuración de la aplicación ClienteAjedrez
# Copia este archivo a ".env" y rellena los valores con tu entorno.

# URL del servidor SignalR (Hub)
# Desarrollo local:
#EXPO_PUBLIC_HUB_URL=https://localhost:7049/ajedrezHub

# Producción:
EXPO_PUBLIC_HUB_URL=https://<tu-servidor>/ajedrezHub

# Flags de debug
EXPO_PUBLIC_DEBUG=true
